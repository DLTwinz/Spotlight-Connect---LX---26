# ============================================
# SPOTLIGHT CONNECT — Environment Variables
# ============================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values below
#   3. NEVER commit .env — only .env.example goes to git
# ============================================

# --- SUPABASE (New publishable key system) ---
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_SERVICE_ROLE_KEY_HERE

# --- FLUTTER DART-DEFINE USAGE ---
# DO NOT run `flutter run` directly.
# Instead, use the helper script:
#   ./run_dev.sh
#
# Or manually:
#   flutter run \
#     --dart-define=SUPABASE_URL=$SUPABASE_URL \
#     --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
